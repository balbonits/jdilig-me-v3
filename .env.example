# Copy to .env.local for local `vercel dev`. In production, set these in
# Vercel → Project → Environment Variables (or via the Resend Marketplace
# integration which auto-provisions RESEND_API_KEY).

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Inbox that contact-form messages are delivered to
CONTACT_TO_EMAIL=you@example.com

# From-address. Use Resend's onboarding domain until you verify your own.
# Once you verify a domain, switch this to e.g. hello@jdilig.me.
CONTACT_FROM_EMAIL=onboarding@resend.dev
